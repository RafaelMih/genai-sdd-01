{
  "name": "genai-sdd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "tsx scripts/install-hooks.ts",
    "dev": "vite",
    "dev:e2e": "vite --mode e2e --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --project tsconfig.app.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "create:feature": "tsx scripts/create-feature.ts",
    "spec:lint": "tsx scripts/spec-lint.ts",
    "spec:trace": "tsx scripts/spec-trace.ts",
    "spec:coverage": "tsx scripts/spec-ac-coverage.ts",
    "spec:drift": "tsx scripts/spec-drift.ts",
    "spec:drift-ui": "tsx scripts/spec-drift-ui.ts",
    "spec:status": "tsx scripts/spec-status.ts",
    "spec:check": "npm run spec:lint && npm run spec:status && npm run spec:trace && npm run spec:coverage && npm run spec:drift && npm run spec:drift-ui",
    "spec:doctor": "tsx scripts/spec-doctor.ts",
    "spec:doctor:fix": "tsx scripts/spec-doctor.ts --fix",
    "governance": "npm run traceability:generate && npm run specs:archive",
    "skill:lint": "tsx scripts/skill-lint.ts",
    "agent:lang-check": "tsx scripts/agent-lang-check.ts",
    "spec:ci": "npm run format && npm run typecheck && npm run lint && npm run spec:doctor && npm run test && npm run skill:lint && npm run agent:lang-check && npm run governance",
    "specs:archive": "tsx scripts/specs-archive.ts",
    "precommit:spec": "tsx scripts/precommit-spec.ts",
    "ai:context": "tsx scripts/ai-context.ts",
    "context:generate": "tsx scripts/generate-feature-contexts.ts",
    "traceability:generate": "tsx scripts/generate-traceability-summaries.ts",
    "context:report": "tsx scripts/context-telemetry-report.ts",
    "rag:feedback": "tsx scripts/rag-feedback.ts",
    "mcp:spec": "tsx mcp/spec-rag-mcp.ts",
    "mcp:pokemon": "tsx mcp/pokemon-mcp.ts",
    "mcp:inspect": "npx @modelcontextprotocol/inspector --config .mcp.json",
    "mcp:inspect:spec": "npx @modelcontextprotocol/inspector --config .mcp.json --server spec-rag",
    "mcp:inspect:pokemon": "npx @modelcontextprotocol/inspector --config .mcp.json --server pokemon",
    "codex:mcp:register": "tsx scripts/register-codex-mcp.ts",
    "index:specs": "tsx scripts/index-specs.ts",
    "test": "vitest --run --exclude 'tests/firestore.rules.test.ts'",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts tests/firestore.rules.test.ts\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "firebase": "^12.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
