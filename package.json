{
  "name": "genai-sdd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "create:feature": "tsx scripts/create-feature.ts",
    "spec:lint": "tsx scripts/spec-lint.ts",
    "spec:trace": "tsx scripts/spec-trace.ts",
    "spec:status": "tsx scripts/spec-status.ts",
    "spec:check": "npm run spec:lint && npm run spec:status",
    "precommit:spec": "tsx scripts/precommit-spec.ts",
    "mcp:spec-rag": "tsx mcp/spec-rag-server.ts",
    "test": "vitest --run --exclude 'tests/firestore.rules.test.ts'",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/firestore.rules.test.ts\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "firebase": "^12.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
